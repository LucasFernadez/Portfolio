---
import { site } from "../data/site";

const nav = [
  { label: "Proyectos", href: "#proyectos" },
  { label: "Tecnologías", href: "#tecnologias" },
  { label: "Contacto", href: "#contacto" },
];
---

<header
  class="sticky top-0 z-50 border-b border-border/60 bg-bg/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 sm:px-8"
  >
    <a href="#" class="flex items-center gap-2 group">
      <img
        src="/favicon.svg"
        alt={site.brand}
        width="28"
        height="28"
        class="h-7 w-7 rounded-md"
      />
      <span class="label-caps text-sm font-semibold">{site.brand}</span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm text-muted transition-colors hover:text-fg"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="#contacto"
      class="hidden rounded-md border border-border bg-surface-2 px-4 py-2 text-sm font-medium transition-colors hover:border-accent hover:text-accent md:inline-block"
      >Hablemos</a
    >

    <!-- Botón mobile -->
    <button
      id="menu-toggle"
      class="flex h-9 w-9 items-center justify-center rounded-md border border-border md:hidden"
      aria-label="Abrir menú"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </nav>

  <!-- Menú mobile desplegable -->
  <div id="mobile-menu" class="hidden border-t border-border/60 md:hidden">
    <ul class="flex flex-col gap-1 px-5 py-3">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="block rounded-md px-3 py-2 text-sm text-muted transition-colors hover:bg-surface-2 hover:text-fg"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));
  // Cierra el menú al pulsar un enlace
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => menu.classList.add("hidden"))
  );
</script>
