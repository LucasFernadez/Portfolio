---
import { site } from "../data/site";
---

<section class="relative overflow-hidden">
  <!-- Resplandor de fondo (con deriva animada) -->
  <div
    class="hero-glow pointer-events-none absolute -top-40 left-1/2 h-[500px] w-[700px] -translate-x-1/2 rounded-full bg-accent/[0.10] blur-[120px]"
  >
  </div>

  <div
    class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-20 sm:px-8 sm:py-28 lg:grid-cols-[1.15fr_0.85fr] lg:gap-12 lg:py-36"
  >
    <!-- Columna de texto -->
    <div class="order-2 text-center lg:order-1 lg:text-left">
      <!-- Diferencial / propuesta de valor -->
      <p
        class="label-caps mb-5 text-xs font-medium text-muted sm:text-[0.8rem]"
      >
        {site.valueProp}
      </p>

      <h1
        class="hero-title text-5xl font-extrabold leading-[1.05] tracking-tight sm:text-6xl lg:text-7xl"
      >
        {
          site.headline.map((word, i) => (
            <span
              class:list={[
                "hero-word",
                site.highlight.includes(word) && "text-accent",
              ]}
              style={`--word-delay: ${i * 110}ms`}
            >
              {word}
              {" "}
            </span>
          ))
        }
      </h1>

      <p
        class="mx-auto mt-8 max-w-xl text-base leading-relaxed text-secondary sm:text-lg lg:mx-0"
      >
        {site.tagline}
      </p>

      <div
        class="mt-10 flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start"
      >
        <a
          href="#contacto"
          class="inline-flex items-center justify-center rounded-md bg-accent px-6 py-3 text-sm font-semibold text-bg transition-all hover:bg-accent-soft hover:-translate-y-0.5"
          >Contáctame</a
        >
        <a
          href="#proyectos"
          class="inline-flex items-center justify-center rounded-md border border-border bg-surface-2 px-6 py-3 text-sm font-medium text-secondary transition-all hover:-translate-y-0.5 hover:border-muted hover:bg-surface hover:text-fg"
          >Ver mis proyectos</a
        >
      </div>
    </div>

    <!-- Columna del retrato line-art -->
    <div class="order-1 flex justify-center lg:order-2 lg:justify-end">
      <div class="relative">
        <!-- Glow sutil detrás del retrato -->
        <div
          class="pointer-events-none absolute inset-0 -z-10 scale-90 rounded-full bg-accent/[0.12] blur-3xl"
        >
        </div>
        <img
          src="/profile-lineart.png"
          alt={site.name}
          width="1008"
          height="892"
          class="hero-portrait h-64 w-auto select-none sm:h-80 lg:h-[26rem]"
        />
      </div>
    </div>
  </div>
</section>

<style>
  /* Entrada del título palabra por palabra */
  .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.5em);
    animation: hero-word-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--word-delay, 0ms);
  }

  @keyframes hero-word-in {
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* Retrato con flotación suave continua */
  .hero-portrait {
    animation: hero-float 6s ease-in-out infinite;
  }

  @keyframes hero-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-14px);
    }
  }

  /* Deriva lenta del resplandor de fondo */
  .hero-glow {
    animation: hero-glow-drift 12s ease-in-out infinite;
  }

  @keyframes hero-glow-drift {
    0%,
    100% {
      transform: translateX(-50%) translateY(0) scale(1);
      opacity: 1;
    }
    50% {
      transform: translateX(-42%) translateY(18px) scale(1.08);
      opacity: 0.85;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-word {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-portrait,
    .hero-glow {
      animation: none;
    }
  }
</style>
