---
import { services } from "../data/site";
---

<section id="servicios" class="border-t border-border/60">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-24">
    <div class="mb-12">
      <p class="label-caps mb-2 text-xs font-medium text-muted">Servicios</p>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Cómo puedo ayudarte
      </h2>
      <p class="mt-3 max-w-lg text-sm text-secondary">
        Del desarrollo al posicionamiento: acompaño tu producto digital de
        principio a fin.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <article class="rounded-xl border border-border bg-surface p-6 transition-colors hover:border-accent/60">
            <h3 class="text-lg font-semibold text-accent">{service.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-secondary">
              {service.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
