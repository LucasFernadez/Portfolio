---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-border/60">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-5 py-12 sm:flex-row sm:justify-between sm:px-8"
  >
    <div class="flex items-center gap-2">
      <img
        src="/favicon.svg"
        alt={site.brand}
        width="28"
        height="28"
        class="h-7 w-7 rounded-md"
      />
      <span class="label-caps text-sm font-semibold">{site.brand}</span>
    </div>

    <div class="flex items-center gap-6 text-sm text-muted">
      <a href="#proyectos" class="transition-colors hover:text-fg">Proyectos</a>
      <a href="#tecnologias" class="transition-colors hover:text-fg">Tecnologías</a>
      <a href="#contacto" class="transition-colors hover:text-fg">Contacto</a>
    </div>

    <p class="text-xs text-muted">
      © {year} {site.name}. Todos los derechos reservados.
    </p>
  </div>
</footer>
