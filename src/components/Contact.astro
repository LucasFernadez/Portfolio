---
import { site } from "../data/site";
---

<section id="contacto" class="border-t border-border/60">
  <div class="mx-auto max-w-3xl px-5 py-20 text-center sm:px-8 sm:py-28" data-reveal>
    <h2 class="text-4xl font-bold tracking-tight sm:text-5xl">Hablemos</h2>
    <p class="mx-auto mt-4 max-w-md text-base text-muted">
      ¿Tienes una idea increíble? Estoy listo para ayudarte a hacerla realidad.
    </p>

    <!-- El formulario envía a FormSubmit, que reenvía a tu email sin backend.
         La primera vez recibirás un email de confirmación de FormSubmit;
         hay que pulsar el enlace de ese correo una sola vez para activarlo.
         Se usa el POST normal (no AJAX) para que el reCAPTCHA de FormSubmit
         se muestre y se valide en su lado. Tras enviar, FormSubmit redirige
         a la URL de _next (vuelta a la sección de contacto con un aviso). -->
    <form
      action={`https://formsubmit.co/${site.email}`}
      method="POST"
      class="mx-auto mt-12 max-w-xl space-y-4 text-left"
    >
      <input type="hidden" name="_subject" value="Nuevo contacto desde el portfolio" />
      <input type="hidden" name="_captcha" value="true" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_next" value={`${site.url}/?enviado=1#contacto`} />
      <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="name" class="mb-1.5 block text-sm text-muted">Tu nombre</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            class="w-full rounded-md border border-border bg-surface px-4 py-3 text-sm outline-none transition-colors placeholder:text-muted/60 focus:border-accent"
            placeholder="Nombre y apellidos"
          />
        </div>
        <div>
          <label for="email" class="mb-1.5 block text-sm text-muted">Correo electrónico</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full rounded-md border border-border bg-surface px-4 py-3 text-sm outline-none transition-colors placeholder:text-muted/60 focus:border-accent"
            placeholder="tucorreo@ejemplo.com"
          />
        </div>
      </div>

      <div>
        <label for="message" class="mb-1.5 block text-sm text-muted">Cuéntame sobre tu proyecto</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full resize-none rounded-md border border-border bg-surface px-4 py-3 text-sm outline-none transition-colors placeholder:text-muted/60 focus:border-accent"
          placeholder="Describe brevemente lo que necesitas…"></textarea>
      </div>

      <button
        type="submit"
        class="w-full rounded-md bg-accent px-6 py-3.5 text-sm font-semibold text-bg transition-colors hover:bg-accent-soft"
        >Enviar mensaje</button
      >

      <!-- Aviso de éxito al volver desde FormSubmit (?enviado=1). Oculto por
           defecto; el script lo muestra si detecta el parámetro en la URL. -->
      <p
        data-form-status
        role="status"
        aria-live="polite"
        class="hidden rounded-md px-4 py-3 text-sm"
      >
      </p>
    </form>

    <!-- Atajos de contacto directo -->
    <div class="mt-10 flex items-center justify-center gap-3">
      <a
        href={`mailto:${site.email}`}
        aria-label="Email"
        class="flex h-11 w-11 items-center justify-center rounded-md border border-border bg-surface-2 text-muted transition-colors hover:border-accent hover:text-accent"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
      </a>
      <a
        href={site.social.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="flex h-11 w-11 items-center justify-center rounded-md border border-border bg-surface-2 text-muted transition-colors hover:border-accent hover:text-accent"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.2 3.44 9.6 8.21 11.16.6.11.82-.25.82-.57 0-.28-.01-1.02-.02-2-3.34.71-4.04-1.58-4.04-1.58-.55-1.36-1.34-1.73-1.34-1.73-1.09-.73.08-.72.08-.72 1.2.08 1.84 1.21 1.84 1.21 1.07 1.79 2.81 1.27 3.5.97.11-.76.42-1.27.76-1.56-2.67-.3-5.47-1.3-5.47-5.8 0-1.28.47-2.33 1.23-3.15-.12-.3-.53-1.5.12-3.14 0 0 1-.31 3.3 1.2a11.6 11.6 0 0 1 6 0c2.28-1.51 3.29-1.2 3.29-1.2.65 1.64.24 2.84.12 3.14.77.82 1.23 1.87 1.23 3.15 0 4.51-2.81 5.5-5.49 5.79.43.36.82 1.09.82 2.2 0 1.59-.01 2.87-.01 3.26 0 .32.21.69.83.57A12.02 12.02 0 0 0 24 12.29C24 5.78 18.63.5 12 .5Z"></path></svg>
      </a>
      <a
        href={site.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="flex h-11 w-11 items-center justify-center rounded-md border border-border bg-surface-2 text-muted transition-colors hover:border-accent hover:text-accent"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"></path></svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* Estados del mensaje de envío (manipulados desde JS) */
  [data-form-status].is-success {
    border: 1px solid color-mix(in srgb, var(--color-accent) 60%, transparent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
  }
  [data-form-status].is-error {
    border: 1px solid color-mix(in srgb, #ef4444 60%, transparent);
    background: color-mix(in srgb, #ef4444 12%, transparent);
    color: #fca5a5;
  }
</style>

<script>
  // Con el POST normal de FormSubmit, el feedback ya no es por AJAX: al enviar,
  // FormSubmit valida el reCAPTCHA y redirige de vuelta a _next con ?enviado=1.
  // Aquí solo detectamos ese parámetro para mostrar el aviso de éxito y limpiar
  // la URL (sin recargar) para que no reaparezca al refrescar.
  function initContactFeedback() {
    const params = new URLSearchParams(window.location.search);
    if (params.get("enviado") !== "1") return;

    const status = document.querySelector<HTMLElement>("[data-form-status]");
    if (status) {
      status.textContent = "¡Mensaje enviado! Te responderé lo antes posible.";
      status.classList.remove("hidden");
      status.classList.add("is-success");
    }

    // Quitar el parámetro de la URL conservando el ancla #contacto.
    params.delete("enviado");
    const query = params.toString();
    const url =
      window.location.pathname + (query ? `?${query}` : "") + "#contacto";
    window.history.replaceState(null, "", url);
  }

  initContactFeedback();
</script>
